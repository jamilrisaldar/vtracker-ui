# --- Mock auth (default): Google + simulated sign-in; data in localStorage mock API ---
# Google OAuth 2.0 Web client ID (optional in mock mode).
VITE_GOOGLE_CLIENT_ID=

# --- Backend auth + domain API (VTracker: cookie `vtracker.sid` + CSRF per Swagger) ---
# When true: login via email/password, and all project/vendor/invoice/etc. calls use the real REST API.
# When false: mock auth (Google/simulated) and localStorage-backed mock data.
VITE_USE_BACKEND_AUTH=false

# API origin for fetches. Leave empty in dev to use the Vite proxy (see vite.config.ts → /api → localhost:3001).
# For a direct origin (must allow CORS + credentials): e.g. http://localhost:3001
VITE_API_BASE_URL=
